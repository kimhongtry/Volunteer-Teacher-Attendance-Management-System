{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext", // ES modules
    "moduleResolution": "node", // resolve like Node.js
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["src"]
}
